GEMINI_API_KEY=your_gemini_api_key_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_long_lived_token_here

# 單人：只設 LINE_USER_ID
LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 多人：設 LINE_USER_IDS（逗號分隔，最多 500 人）；設了這個會忽略上面的 LINE_USER_ID
# LINE_USER_IDS=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx,Uyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
